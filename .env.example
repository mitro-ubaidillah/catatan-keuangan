# Core
NODE_ENV=development
LOG_LEVEL=info
TIMEZONE=Asia/Jakarta

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/catatan_keuangan?schema=public"

# Web Dashboard
WEB_ENABLED="true"
WEB_PORT=3000
WEB_BASE_URL="http://localhost:${WEB_PORT}"
SESSION_SECRET="change-me-please-32-chars-minimum"
ONBOARDING_TOKEN_TTL_HOURS=24
SUBSCRIPTION_TRIAL_DAYS=30
IDP_MESSAGE_TTL_HOURS=72
HEAVY_CMD_RATE_LIMIT_WINDOW_SEC=60
HEAVY_CMD_RATE_LIMIT_MAX=5
HEAVY_JOB_CONCURRENCY=1
BOT_SEND_RETRY_ATTEMPTS=3
BOT_SEND_RETRY_BASE_MS=350
BOT_SEND_RETRY_MAX_MS=2500
SUPERADMIN_EMAIL=""
SUPERADMIN_PASSWORD=""

# Telegram
TELEGRAM_BOT_TOKEN=""

# WhatsApp (Baileys)
WA_ENABLED="true"
WA_SESSION_DIR=".wa_auth"
